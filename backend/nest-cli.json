{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "assets": [
      { "include": "optik/fonts/*.ttf", "outDir": "dist" },
      { "include": "dogrudan-temin/data/*.json", "outDir": "dist", "watchAssets": true },
      { "include": "dogrudan-temin/data/*.xls", "outDir": "dist", "watchAssets": true },
      { "include": "dogrudan-temin/data/*.xlsx", "outDir": "dist", "watchAssets": true },
      { "include": "dogrudan-temin/data/*.csv", "outDir": "dist", "watchAssets": true }
    ]
  }
}
