{
  "name": "ogretmenpro-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && copyfiles -f \"src/optik/fonts/*.ttf\" dist/optik/fonts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "migrate:yillik-plan": "node tools/run-yillik-plan-sql.js",
    "migrate:sql": "node tools/run-sql-migrations.js",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm-data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/config/typeorm-data-source.ts",
    "create-cografya-template": "ts-node -r tsconfig-paths/register scripts/create-cografya-template.ts",
    "create-yillik-plan-templates": "ts-node -r tsconfig-paths/register scripts/create-yillik-plan-templates.ts",
    "upload-plan-r2": "ts-node -r tsconfig-paths/register scripts/upload-plan-to-r2.ts",
    "upload-plan-r2-standalone": "ts-node -r tsconfig-paths/register scripts/upload-plan-to-r2-standalone.ts",
    "seed-doc-cografya": "ts-node -r tsconfig-paths/register scripts/seed-document-template-cografya.ts",
    "check-doc-cografya": "ts-node -r tsconfig-paths/register scripts/check-doc-template-cografya.ts",
    "inject-placeholders-yillik-plan": "ts-node -r tsconfig-paths/register scripts/inject-placeholders-yillik-plan.ts",
    "create-modern-yillik-plan": "ts-node -r tsconfig-paths/register scripts/create-modern-yillik-plan-template.ts",
    "seed-work-calendar": "ts-node -r tsconfig-paths/register scripts/seed-work-calendar-and-plan.ts",
    "seed-content": "ts-node -r tsconfig-paths/register scripts/seed-content-module.ts",
    "seed-classes-subjects": "ts-node -r tsconfig-paths/register scripts/seed-classes-subjects-all-schools.ts",
    "seed-optik-form-templates": "ts-node -r tsconfig-paths/register scripts/seed-optik-form-templates.ts",
    "run-content-sync": "ts-node -r tsconfig-paths/register scripts/run-content-sync.ts",
    "run-exam-duty-sync": "ts-node -r tsconfig-paths/register scripts/run-exam-duty-sync.ts",
    "test-exam-duty-sync-twice": "ts-node -r tsconfig-paths/register scripts/test-exam-duty-sync-twice.ts",
    "backfill-content-images": "ts-node -r tsconfig-paths/register scripts/backfill-content-images.ts",
    "clear-placeholder-images": "ts-node -r tsconfig-paths/register scripts/clear-placeholder-images.ts",
    "set-user-password": "node tools/set-user-password.cjs",
    "ensure-demo-superadmin": "node tools/ensure-demo-superadmin.cjs",
    "peek-app-config": "node tools/peek-app-config.cjs",
    "export-app-config-sql": "node tools/export-app-config-sql.cjs",
    "export-extra-lesson-sql": "node tools/export-extra-lesson-sql.cjs",
    "export-superadmin-full-sql": "node tools/export-superadmin-full-sql.cjs",
    "export:data-mirror": "node tools/export-superadmin-full-sql.cjs ../data-mirror.sql --skip-app-config",
    "placement-feed:gpt": "ts-node -r tsconfig-paths/register src/tools/placement-feed-from-gpt.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "@aws-sdk/s3-request-presigner": "^3.989.0",
    "@fontsource/dejavu-sans": "^5.2.5",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@types/qrcode": "^1.5.6",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dejavu-fonts-ttf": "^2.37.3",
    "docx": "^9.5.2",
    "docxtemplater": "^3.68.1",
    "dotenv": "^17.2.4",
    "fast-xml-parser": "^5.3.5",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^10.6.2",
    "node-unrar-js": "^2.0.2",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "pizzip": "^3.2.0",
    "playwright": "^1.49.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.7",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
