# Ortam
APP_ENV=local
# Canlıda demo hesapları (seed/demo-credentials.ts) — güvenlik riski; yalnız geçiş/test için
# ALLOW_DEMO_LOGIN=true
APP_DEBUG=true
APP_PORT=4000
APP_URL=http://localhost:4000
# Canlıda scripts/deploy/server-deploy.sh her dağıtımda yazar (GET /api/health/deployment)
# DEPLOY_GIT_SHA=
# TypeORM otomatik şema (local). Sorun çıkarsa false + migration SQL kullanın.
# TYPEORM_SYNC=true

# Veritabanı (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ogretmenpro
DB_USERNAME=postgres
# Guclu sifre: en az 24 karakter rastgele (harf+rakam). Uretim: scripts/security/generate-db-password.ps1
DB_PASSWORD=
# PostgreSQL bağlantı havuzu (node-pg; yüksek trafikte artırın)
# DB_POOL_MAX=20
# DB_POOL_IDLE_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=10000

# Firebase Admin SDK (Google / Apple / SMS ile girişte id_token doğrulama — aynı Firebase projesi)
# Firebase Console → Project settings → Service accounts → Generate new private key (JSON)
# JSON içindeki project_id → FIREBASE_PROJECT_ID, client_email → FIREBASE_CLIENT_EMAIL,
# private_key → FIREBASE_PRIVATE_KEY (tek satırda \\n ile satır sonları; tırnak içinde)
# web-admin/.env.local içindeki NEXT_PUBLIC_FIREBASE_PROJECT_ID bu project_id ile AYNI olmalı.
# SMS ile giriş: Firebase Console → Authentication → Sign-in method → Phone etkin; web-admin’de APP_ID + MESSAGING_SENDER_ID gerekir.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# JWT (opsiyonel; Firebase kullanılmıyorsa yerel token)
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRE=86400

# WordPress (içerik – C aşamasında)
WP_BASE_URL=https://example.com
WP_API_PATH=/wp-json

# CORS (Web Admin + mobil origin)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Şifre sıfırlama / oturum çerezi (canlı: https://admin... — SESSION_COOKIE_DOMAIN ile birlikte)
FRONTEND_URL=http://localhost:3000
# İsteğe bağlı: admin+api alt alanında çerez (boşsa production+FRONTEND_URL=uzaedu ise .uzaedu.com)
# SESSION_COOKIE_DOMAIN=.uzaedu.com
# Nginx arkasında (çoğu canlı kurulumda açık; kapatmak için TRUST_PROXY=false)
# TRUST_PROXY=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ogretmenpro.com

# OpenAI (GPT taslak – Yıllık Plan İçerikleri)
# https://platform.openai.com/api-keys adresinden alın
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# Öğretmen evrak jetonu: production’da kota zorunlu. Geçici muafiyet için 1; zorunlu kılmak için 0.
# Local’de NODE_ENV=development iken kota kontrolü/düşümü yapılmaz.
# EVRAK_SKIP_TEACHER_QUOTA=1

# R2 (upload-plan-r2-standalone script için – Admin Ayarlar'dan kopyalanabilir)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Market — Google Play sunucu doğrulaması (JSON dosya yolu veya tek satır JSON)
# GOOGLE_PLAY_PACKAGE_NAME=com.example.app
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Market — Apple verifyReceipt paylaşılan gizli anahtar (App Store Connect)
# APPLE_SHARED_SECRET=

# --- Canlı sunucu: panelden “Güncelle” (şifre + onay + betik). Windows’ta API çalışırsa panel bu özelliği göstermez. ---
# Nginx arkasında doğru istemci IP için:
# TRUST_PROXY=true
# DEPLOY_ENABLED=true
# DEPLOY_SECRET=2295
# DEPLOY_SCRIPT_PATH=/opt/ogretmenpro/deploy.sh
# İsteğe bağlı — yalnızca bu IP’ler (virgülle, X-Forwarded-For ile uyumlu):
# DEPLOY_ALLOWED_IPS=203.0.113.10,198.51.100.0
# İsteğe bağlı — ikinci gizli değer (panelde “Ek doğrulama”; body veya X-Deploy-Token):
# DEPLOY_HEADER_TOKEN=baska-uzun-gizli-deger
#
# Yerel Windows: tools/deploy-local-to-prod.ps1 (SQL export + scp + psql) — PowerShell oturumunda:
# $env:DEPLOY_SSH_HOST="sunucu-ip"
# $env:DEPLOY_SSH_KEY="$env:USERPROFILE\.ssh\id_rsa_uzaedu"
# $env:DEPLOY_REMOTE_ROOT="/opt/uzaedu"
# Sunucu deploy betigi: MIGRATE_ON_DEPLOY=1 ile pull sonrasi migration:run (istege bagli)

# Destek talepleri — "Bilgi bekleniyor" durumunda açan kişi belirtilen gün içinde cevap vermezse otomatik kapanır.
# 0 veya negatif değer verirseniz otomatik kapatma devre dışı kalır.
# TICKETS_AUTO_CLOSE_WAITING_REQUESTER_DAYS=7
