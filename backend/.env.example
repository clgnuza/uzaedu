# Ortam
APP_ENV=local
APP_DEBUG=true
APP_PORT=4000
APP_URL=http://localhost:4000
# TypeORM otomatik şema (local). Sorun çıkarsa false + migration SQL kullanın.
# TYPEORM_SYNC=true

# Veritabanı (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ogretmenpro
DB_USERNAME=postgres
DB_PASSWORD=

# Firebase Admin SDK (token doğrulama + ileride push)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# JWT (opsiyonel; Firebase kullanılmıyorsa yerel token)
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRE=86400

# WordPress (içerik – C aşamasında)
WP_BASE_URL=https://example.com
WP_API_PATH=/wp-json

# CORS (Web Admin + mobil origin)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Şifre sıfırlama
FRONTEND_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ogretmenpro.com

# OpenAI (GPT taslak – Yıllık Plan İçerikleri)
# https://platform.openai.com/api-keys adresinden alın
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# Öğretmen evrak jetonu: production’da kota zorunlu. Geçici muafiyet için 1; zorunlu kılmak için 0.
# Local’de NODE_ENV=development iken kota kontrolü/düşümü yapılmaz.
# EVRAK_SKIP_TEACHER_QUOTA=1

# R2 (upload-plan-r2-standalone script için – Admin Ayarlar'dan kopyalanabilir)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Market — Google Play sunucu doğrulaması (JSON dosya yolu veya tek satır JSON)
# GOOGLE_PLAY_PACKAGE_NAME=com.example.app
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Market — Apple verifyReceipt paylaşılan gizli anahtar (App Store Connect)
# APPLE_SHARED_SECRET=
