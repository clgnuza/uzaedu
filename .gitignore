# Uzaedu Öğretmen – Ortak .gitignore taslağı
# Backend/Web/Flutter eklenince ilgili bloklar açılır veya alt projelere taşınır.

# Ortam ve gizlilik (asla commit edilmez)
.env
.env.local
.env.*.local
*.env
!.env.example
!web-admin/.env.production.example
firebase-admin-key.json
**/google-services.json
**/GoogleService-Info.plist

# IDE / editör
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# app_config export (gizli anahtarlar içerir)
/app-config-import.sql
/extra-lesson-import.sql
/superadmin-full-import.sql
/data-mirror.sql
/full-mirror-import.sql
/full-mirror.sql
/_test-full.sql

# Log ve geçici
*.log
tmp/
temp/
.cache/

# Backend (Node/Nest/TS)
backend/node_modules/
backend/dist/
backend/build/
backend/data/
backend/uploads/

# Web Admin (Next.js)
web-admin/.next/
web-admin/out/

# Local artifacts
trust_debug.txt
yolluk2026.xls
backend/test.txt
backend/_*.html
backend/hesap_plani.csv
hesap_plani.csv
convert_excel.py
gen_sql.py
gen_full_sql.py
backend/load-materials.js

# Flutter (proje eklendiğinde kullan)
# .dart_tool/
# .packages
# build/
# .flutter-plugins
# .flutter-plugins-dependencies
# *.iml

# Test / coverage
# coverage/
# .nyc_output/
# *.lcov
