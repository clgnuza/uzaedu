{
  "manifest_version": 3,
  "name": "Uzaedu Okul Köprüsü",
  "version": "0.4.0",
  "description": "Uzaedu paneli ile OkulNet arasında güvenli veri köprüsü.",
  "permissions": ["tabs", "storage", "scripting", "alarms", "downloads"],
  "host_permissions": [
    "http://127.0.0.1:4000/*",
    "http://localhost:4000/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://0.0.0.0:3000/*",
    "https://e-okul.meb.gov.tr/*",
    "https://eokulyd.meb.gov.tr/*",
    "https://mebbis.meb.gov.tr/*",
    "https://www.mebbis.meb.gov.tr/*",
    "https://mebbisyd.meb.gov.tr/*",
    "https://www.mebbisyd.meb.gov.tr/*",
    "https://kbs.muhasebat.gov.tr/*",
    "https://www.kbs.muhasebat.gov.tr/*",
    "https://admin.uzaedu.com/*",
    "https://uzaedu.com/*",
    "https://www.uzaedu.com/*",
    "https://api.uzaedu.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Uzaedu Okul Köprüsü",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://e-okul.meb.gov.tr/*", "https://eokulyd.meb.gov.tr/*"],
      "js": ["content/eokul-confirm-bypass.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://e-okul.meb.gov.tr/*", "https://eokulyd.meb.gov.tr/*"],
      "js": ["content/eokul-devamsizlik-panel.js", "content/eokul-sesli-rapor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mebbis.meb.gov.tr/*",
        "https://www.mebbis.meb.gov.tr/*",
        "https://mebbisyd.meb.gov.tr/*",
        "https://www.mebbisyd.meb.gov.tr/*",
        "https://kbs.muhasebat.gov.tr/*",
        "https://www.kbs.muhasebat.gov.tr/*"
      ],
      "js": ["content/bordro-scrape.js", "content/bordro-export-hook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://0.0.0.0:3000/*",
        "https://admin.uzaedu.com/*",
        "https://uzaedu.com/*",
        "https://www.uzaedu.com/*"
      ],
      "js": ["content/siteBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
  }
}
