{
  "manifest_version": 3,
  "name": "Uzaedu Okul Köprüsü",
  "version": "0.6.23",
  "description": "Uzaedu paneli ile e-Okul arasında güvenli veri köprüsü.",
  "permissions": ["tabs", "storage", "scripting", "alarms", "downloads", "cookies", "offscreen"],
  "host_permissions": [
    "http://127.0.0.1:4000/*",
    "http://localhost:4000/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://0.0.0.0:3000/*",
    "https://e-okul.meb.gov.tr/*",
    "https://eokulyd.meb.gov.tr/*",
    "https://mebbis.meb.gov.tr/*",
    "https://www.mebbis.meb.gov.tr/*",
    "https://mebbisyd.meb.gov.tr/*",
    "https://www.mebbisyd.meb.gov.tr/*",
    "https://kbs.muhasebat.gov.tr/*",
    "https://www.kbs.muhasebat.gov.tr/*",
    "https://kbs.gov.tr/*",
    "https://www.kbs.gov.tr/*",
    "https://giris.hmb.gov.tr/*",
    "https://ebys.meb.gov.tr/*",
    "https://www.ebys.meb.gov.tr/*",
    "https://meb.k12.tr/*",
    "https://*.meb.k12.tr/*",
    "https://tefbis.meb.gov.tr/*",
    "https://www.tefbis.meb.gov.tr/*",
    "https://e-kurs.meb.gov.tr/*",
    "https://www.e-kurs.meb.gov.tr/*",
    "https://ekurs.meb.gov.tr/*",
    "https://www.ekurs.meb.gov.tr/*",
    "https://admin.uzaedu.com/*",
    "https://uzaedu.com/*",
    "https://www.uzaedu.com/*",
    "https://api.uzaedu.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Uzaedu Okul Köprüsü — paneli aç/kapat",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/float-host.css",
        "assets/*",
        "gate/*",
        "app/*",
        "menus/*",
        "shared/*"
      ],
      "matches": [
        "https://e-okul.meb.gov.tr/*",
        "https://eokulyd.meb.gov.tr/*",
        "https://mebbis.meb.gov.tr/*",
        "https://www.mebbis.meb.gov.tr/*",
        "https://mebbisyd.meb.gov.tr/*",
        "https://www.mebbisyd.meb.gov.tr/*",
        "https://kbs.muhasebat.gov.tr/*",
        "https://www.kbs.muhasebat.gov.tr/*",
        "https://kbs.gov.tr/*",
        "https://www.kbs.gov.tr/*",
    "https://giris.hmb.gov.tr/*",
        "https://ebys.meb.gov.tr/*",
        "https://www.ebys.meb.gov.tr/*",
        "https://meb.k12.tr/*",
        "https://*.meb.k12.tr/*",
        "https://tefbis.meb.gov.tr/*",
        "https://www.tefbis.meb.gov.tr/*",
        "https://e-kurs.meb.gov.tr/*",
        "https://www.e-kurs.meb.gov.tr/*",
        "https://ekurs.meb.gov.tr/*",
        "https://www.ekurs.meb.gov.tr/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://0.0.0.0:3000/*",
        "https://admin.uzaedu.com/*",
        "https://uzaedu.com/*",
        "https://www.uzaedu.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://e-okul.meb.gov.tr/*",
        "https://eokulyd.meb.gov.tr/*",
        "https://mebbis.meb.gov.tr/*",
        "https://www.mebbis.meb.gov.tr/*",
        "https://mebbisyd.meb.gov.tr/*",
        "https://www.mebbisyd.meb.gov.tr/*",
        "https://kbs.muhasebat.gov.tr/*",
        "https://www.kbs.muhasebat.gov.tr/*",
        "https://kbs.gov.tr/*",
        "https://www.kbs.gov.tr/*",
    "https://giris.hmb.gov.tr/*",
        "https://ebys.meb.gov.tr/*",
        "https://www.ebys.meb.gov.tr/*",
        "https://meb.k12.tr/*",
        "https://*.meb.k12.tr/*",
        "https://tefbis.meb.gov.tr/*",
        "https://www.tefbis.meb.gov.tr/*",
        "https://e-kurs.meb.gov.tr/*",
        "https://www.e-kurs.meb.gov.tr/*",
        "https://ekurs.meb.gov.tr/*",
        "https://www.ekurs.meb.gov.tr/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://0.0.0.0:3000/*",
        "https://admin.uzaedu.com/*",
        "https://uzaedu.com/*",
        "https://www.uzaedu.com/*"
      ],
      "js": ["content/float-host.js"],
      "css": [],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://e-okul.meb.gov.tr/*", "https://eokulyd.meb.gov.tr/*"],
      "js": ["content/eokul-confirm-bypass.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://e-okul.meb.gov.tr/*", "https://eokulyd.meb.gov.tr/*"],
      "js": [
        "content/eokul-oturum-ping.js",
        "content/eokul-devamsizlik-panel.js",
        "content/eokul-sesli-rapor.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kbs.gov.tr/maasRapor/*",
        "https://www.kbs.gov.tr/maasRapor/*",
        "https://kbs.gov.tr/yeniakademik/*",
        "https://www.kbs.gov.tr/yeniakademik/*"
      ],
      "js": ["content/bordro-kbs-export-sniff.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://mebbis.meb.gov.tr/*",
        "https://www.mebbis.meb.gov.tr/*",
        "https://mebbisyd.meb.gov.tr/*",
        "https://www.mebbisyd.meb.gov.tr/*",
        "https://kbs.muhasebat.gov.tr/*",
        "https://www.kbs.muhasebat.gov.tr/*",
        "https://kbs.gov.tr/*",
        "https://www.kbs.gov.tr/*",
        "https://giris.hmb.gov.tr/*"
      ],
      "js": ["content/bordro-scrape.js", "content/bordro-export-hook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://ebys.meb.gov.tr/*",
        "https://www.ebys.meb.gov.tr/*",
        "https://meb.k12.tr/*",
        "https://*.meb.k12.tr/*",
        "https://tefbis.meb.gov.tr/*",
        "https://www.tefbis.meb.gov.tr/*",
        "https://e-kurs.meb.gov.tr/*",
        "https://www.e-kurs.meb.gov.tr/*",
        "https://ekurs.meb.gov.tr/*",
        "https://www.ekurs.meb.gov.tr/*"
      ],
      "js": ["content/meb-oturum-ping.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://0.0.0.0:3000/*",
        "https://admin.uzaedu.com/*",
        "https://uzaedu.com/*",
        "https://www.uzaedu.com/*"
      ],
      "js": ["shared/panel-api-base.js", "content/siteBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; font-src 'self';"
  }
}
