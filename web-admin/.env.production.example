# web-admin canlı build (.env.production olarak kopyalayın; NEXT_PUBLIC_* build anında gömülür)
NEXT_PUBLIC_API_BASE_URL=https://api.uzaedu.com/api
NEXT_PUBLIC_SITE_URL=https://uzaedu.com

# Cloudflare Web Analytics (panelde otomatik script enjeksiyonu KAPALI olmalı — çift yükleme ve SRI hatası olmasın)
