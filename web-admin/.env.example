# Core Backend API (proje kökü ENV_EXAMPLE.md ile uyumlu)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
# İsteğe bağlı: /deploy (Sunucuyu güncelle) için farklı API — boşsa localhost API kullanılırken otomatik canlı API (LIVE) seçilir.
# NEXT_PUBLIC_DEPLOY_API_BASE_URL=https://api.uzaedu.com/api
#
# --- Aynı Wi‑Fi’den telefon ile test (PC’nin IPv4’sü, ipconfig): ---
# `npm run dev:lan` kullan. .env.local içinde geçici olarak:
# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.XX:4000/api
# NEXT_PUBLIC_SITE_URL=http://192.168.1.XX:3000
# backend/.env → CORS_ORIGINS içine http://192.168.1.XX:3000 ekle. Sonra web-admin’i yeniden başlat.
# Oturum: girişte backend httpOnly çerez (ogp_session) set eder; istekler credentials: include ile gider.
# CORS için backend CORS_ORIGINS bu origin’i içermelidir.

# Production build’de öğretmen yıllık plan arayüzünde evrak kotası kilidini kapatmak: NEXT_PUBLIC_EVRAK_SKIP_TEACHER_QUOTA=1
# (Development’ta kota UI zaten kapalıdır.)

# Site base URL – canonical, OG url için (production: https://uzaedu.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Drive — ayarlar yedeği (OAuth Web istemci ID; Drive API açık olmalı)
# NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=

# Firebase (Web Admin – Google/Apple/Telefon girişi)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
