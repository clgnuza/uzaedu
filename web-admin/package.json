{
  "name": "web-admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000 --webpack",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000 --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:optik": "npx --yes tsx src/lib/optik-session-summary.test.ts && npx --yes tsx src/lib/optik-blob-download.test.ts && npx --yes tsx src/lib/optik-session-report-load.test.ts && npx --yes tsx src/lib/optik-omr-decode.test.ts && npm run test:optik-golden",
    "test:optik-golden": "npx --yes tsx src/lib/optik-omr-golden.test.ts",
    "generate:optik-golden-ppm": "npx --yes tsx scripts/generate-optik-golden-ppm.ts",
    "optik:golden:ppm": "npx --yes tsx scripts/generate-optik-golden-ppm.ts",
    "pwa:assets": "node scripts/generate-pwa-brand-assets.mjs",
    "pwa:push-icons": "node scripts/generate-push-notification-assets.mjs",
    "pwa:sw-push": "npx --yes esbuild src/sw-push-standalone.ts --bundle --outfile=public/sw-push.js --format=iife --target=es2020",
    "pwa:lighthouse": "npx --yes lighthouse http://127.0.0.1:3000/dashboard --only-categories=pwa --output=html --output-path=./lighthouse-pwa.html --chrome-flags=\"--headless=new\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@simplewebauthn/browser": "^13.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.11.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@serwist/next": "^9.5.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "serwist": "^9.5.11",
    "sharp": "^0.34.5",
    "typescript": "^5"
  }
}
